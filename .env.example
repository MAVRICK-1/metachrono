# OpenMetadata connection
OPENMETADATA_URL=https://sandbox.open-metadata.org/api/v1
OPENMETADATA_JWT_TOKEN=
OPENMETADATA_USERNAME=admin
OPENMETADATA_PASSWORD=admin

# AI providers (priority: Gemini → OpenAI → rule-based fallback)
# Free: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Optional paid fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Frontend
REACT_APP_API_URL=http://localhost:8000/api/v1

# Firebase (optional — enables Google Sign-In + Firestore)
# Run: firebase apps:sdkconfig WEB --project YOUR_PROJECT_ID
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
